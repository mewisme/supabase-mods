# Pins for PostgreSQL / Supabase major 17.
# Paired with Dockerfile.17

POSTGRES_MAJOR=17
POSTGRES_IMAGE=supabase/postgres:17.6.1.143
POSTGRES_VERSION=17.6.1.143
POSTGRES_SRC_VERSION=17.6
POSTGRES_SRC_URL=https://ftp.postgresql.org/pub/source/v17.6/postgresql-17.6.tar.bz2
POSTGRES_SRC_SHA256=e0630a3600aea27511715563259ec2111cd5f4353a4b040e0be827f94cd7a8b0

# glibc builder — Supabase Postgres is Nix/glibc; Alpine/musl toolchains cannot produce loadable .so files.
GLIBC_BUILDER_IMAGE=postgres:17.6-bookworm
