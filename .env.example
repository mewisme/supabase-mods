# Copy to .env and adjust as needed.
# docker compose up -d
#
# Select major track via POSTGRES_MAJOR (must match Dockerfile.N + versions/N.env).

POSTGRES_MAJOR=17
POSTGRES_IMAGE=supabase/postgres:17.6.1.143
POSTGRES_VERSION=17.6.1.143
IMAGE_NAME=mewisme/supabase-mods
# Compose image tag: latest | 17 | 17.6.1.143 | 17-bN | local | ...
IMAGE_TAG=latest
GLIBC_BUILDER_IMAGE=postgres:17.6-bookworm
POSTGRES_PORT=5432

# Bootstrap credentials (docker-entrypoint). Upstream default user is supabase_admin.
POSTGRES_USER=supabase_admin
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
# Extra databases (comma-separated). Created only on first init (empty pgdata volume).
# Example: POSTGRES_DATABASES=app,analytics,staging
POSTGRES_DATABASES=
