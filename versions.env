# Shared defaults. Per-major pins live in versions/<MAJOR>.env (e.g. versions/17.env).
# CI discovers Dockerfile.[0-9]+; latest follows the highest major.

DEFAULT_MAJOR=17
IMAGE_NAME=mewisme/supabase-mods
MODS_LIBDIR=/opt/supabase-mods/lib
MODS_PROFILE_OVERLAY=/opt/supabase-mods/nix-profile
SUPAUTILS_CONF=/etc/postgresql-custom/supautils.conf
